# Optional API keys for the project-social-playbook skill.
# Required only for live fetching/search - the skill itself doesn't need this.
ANTHROPIC_API_KEY=


# All keys are optional - the skill works with none of them set, using the
# bundled project-launch library. Each key upgrades one capability.

# --- X post fetching (for project-account grounding) ---

# Recommended: twitterapi.io - $0.15 per 1000 tweets, free signup credit
# Get one at: https://twitterapi.io
TWITTERAPI_IO_KEY=

# Additional option: Xquik API key
# Get one at: https://xquik.com
XQUIK_API_KEY=

# Fallback: RapidAPI key (uses twitter-api45 provider by default)
# Get one at: https://rapidapi.com
RAPIDAPI_KEY=

# --- Web search (for project background and community enrichment) ---

# Recommended: Tavily - 1000/mo free, no credit card
# Get one at: https://tavily.com
TAVILY_API_KEY=

# Alternative: Exa - $10 one-time credits
# Get one at: https://exa.ai
EXA_API_KEY=

# Alternative: SerpAPI - 100/mo free
# Get one at: https://serpapi.com
SERPAPI_KEY=
